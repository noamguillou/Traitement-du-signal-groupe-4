    "\n",
    "fig4, ax4 = plt.subplots()\n",
    "ax4.plot(xrd[:,0]*1000, label='Première colonne de xrd')\n",
    "ax4.plot(xrd[:,1]*1000, label='Deuxième colonne de xrd')\n",
