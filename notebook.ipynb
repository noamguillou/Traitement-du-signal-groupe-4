   "source": [
    "# ── Paramètres ──────────────────────────────────────────────────\n",
    "fc   = 77e9\n",
    "B    = 150e6\n",
    "T_chirp = (22/3)*1e-6\n",
    "c    = 3e8\n",
    "fech = 1.2e9   # fs\n",
    "\n",
    "# ── Xrd déjà calculée colonne par colonne (shape : N_fft//2 x N_chirp) ──\n",
    "# (on suppose que Xrd a été calculée dans la cellule précédente)\n",
    "\n",
    "N_chirp = Xrd.shape[1]\n",
    "indices_chirp = np.arange(N_chirp)\n",
    "\n",
    "# ── 1) Visualiser une ligne de xrd (partie réelle et imaginaire) ──\n",
    "# Prendre une ligne quelconque au milieu du signal\n",
    "k_ligne = xrd.shape[0] // 2   # ligne centrale de xrd\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 4))\n",
    "\n",
    "axes[0].plot(indices_chirp, np.real(xrd[k_ligne, :]), label='Partie réelle')\n",
    "axes[0].plot(indices_chirp, np.imag(xrd[k_ligne, :]), label='Partie imaginaire', linestyle='--')\n",
    "axes[0].set_xlabel('Indice chirp n')\n",
    "axes[0].set_ylabel('Amplitude')\n",
    "axes[0].set_title(f'xrd : ligne k={k_ligne}')\n",
    "axes[0].legend()\n",
    "axes[0].grid()\n",
    "\n",
    "# ── 2) Trouver le bin de distance dominant dans Xrd ──────────────\n",
    "freqs_range = np.fft.fftfreq(N_fft, d=1/fech)[:N_fft//2]\n",
    "distances   = (freqs_range * T_chirp * c) / (2 * B)\n",
    "\n",
    "# Énergie par bin de distance (somme sur les chirps)\n",
    "energie_par_bin = np.sum(np.abs(Xrd)**2, axis=1)\n",
    "m_star = np.argmax(energie_par_bin)\n",
    "print(f\"Bin dominant m* = {m_star}  →  distance estimée = {distances[m_star]:.1f} m\")\n",
    "\n",
    "# ── 3) Visualiser la ligne m* de Xrd ─────────────────────────────\n",
    "axes[1].plot(indices_chirp, np.real(Xrd[m_star, :]), label='Partie réelle')\n",
    "axes[1].plot(indices_chirp, np.imag(Xrd[m_star, :]), label='Partie imaginaire', linestyle='--')\n",
    "axes[1].set_xlabel('Indice chirp n')\n",
    "axes[1].set_ylabel('Amplitude')\n",
    "axes[1].set_title(f'Xrd : ligne m*={m_star} (distance ≈ {distances[m_star]:.1f} m)')\n",
    "axes[1].legend()\n",
    "axes[1].grid()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ── 4) Superposer la sinusoïde théorique ─────────────────────────\n",
    "# Estimation de ṙ depuis la FFT Doppler de la ligne m* de Xrd\n",
    "fft_doppler = np.fft.fft(Xrd[m_star, :])\n",
    "freqs_doppler = np.fft.fftfreq(N_chirp, d=T_chirp)\n",
    "idx_doppler   = np.argmax(np.abs(fft_doppler))\n",
    "f_doppler     = freqs_doppler[idx_doppler]\n",
    "rdot_estime   = f_doppler * c / (2 * fc)\n",
    "print(f\"Vitesse estimée ṙ = {rdot_estime:.2f} m/s\")\n",
    "\n",
    "# Sinusoïde théorique\n",
    "sinusoide_th = np.abs(Xrd[m_star, 0]) * np.exp(\n",
    "    1j * 2 * np.pi * (2 * fc / c) * rdot_estime * indices_chirp * T_chirp\n",
    ")\n",
    "\n",
    "fig2, ax = plt.subplots(figsize=(10, 4))\n",
    "ax.plot(indices_chirp, np.real(Xrd[m_star, :]), label='Re(Xrd[m*,n])', alpha=0.8)\n",
    "ax.plot(indices_chirp, np.real(sinusoide_th), '--', label='Sinusoïde théorique', lw=2)\n",
    "ax.set_xlabel('Indice chirp n')\n",
    "ax.set_ylabel('Amplitude')\n",
    "ax.set_title('Ligne m* de Xrd vs sinusoïde théorique')\n",
    "ax.legend(); ax.grid()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
